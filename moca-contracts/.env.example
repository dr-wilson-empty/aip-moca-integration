# Moca Chain Testnet — used only for deploy / live network (not for local compile or test)
MOCA_RPC_URL=https://rpc.testnet.mocachain.dev
MOCA_CHAIN_ID=222888

# Deployer key: a 0x-prefixed private key for a wallet funded from https://faucet.mocachain.org
# NEVER commit the real value. Copy this file to .env and fill it in before deploying.
DEPLOYER_PRIVATE_KEY=
