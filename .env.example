# =====================================================================
# AIP — Environment Variables
# Copy to .env.local and fill in your values.
# =====================================================================

# App URL (your deployed domain)
NEXT_PUBLIC_APP_URL=https://your-domain.netlify.app

# Solana Network
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# USDC SPL Token Mint (Devnet)
USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Escrow Authority Wallet (generate: node -e "const k=require('@solana/web3.js').Keypair.generate();console.log(require('bs58').default.encode(k.secretKey))")
ESCROW_PRIVATE_KEY=<your-base58-encoded-secret-key>

# Anthropic API (Claude — agent AI engine)
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# Supabase
SUPABASE_URL=<your-supabase-url>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>
NEXT_PUBLIC_SUPABASE_URL=<your-supabase-url>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Tavily API (web search agent)
TAVILY_API_KEY=<your-tavily-api-key>

# Firecrawl API (web scraping, optional)
FIRECRAWL_API_KEY=<your-firecrawl-api-key>

# =====================================================================
# Moca AIR Kit (optional identity layer)
# Partner ID + Issuer/Verifier DID from https://developers.sandbox.air3.com
# =====================================================================
NEXT_PUBLIC_AIRKIT_PARTNER_ID=<your-partner-id>
AIRKIT_ISSUER_DID=<your-issuer-did>
AIRKIT_VERIFIER_DID=<your-verifier-did>
AIRKIT_SIGNING_ALGORITHM=RS256
# Base64 of the full PEM files:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out priv.pem
#   openssl rsa -in priv.pem -pubout -out pub.pem
#   base64 < priv.pem | tr -d '\n'   (and the same for pub.pem)
AIRKIT_PARTNER_PRIVATE_KEY_B64=<base64-of-private-key-pem>
AIRKIT_PARTNER_PUBLIC_KEY_B64=<base64-of-public-key-pem>
# Program IDs created in the dashboard (Issuer -> Programs, Verifier -> Programs)
AIRKIT_VERIFIED_AGENT_PROGRAM_ID=<issuance-program-id>
AIRKIT_VERIFY_PROGRAM_ID=<verification-program-id>
# Optional: defaults to sandbox
# AIRKIT_API_BASE=https://api.sandbox.mocachain.org/v1
